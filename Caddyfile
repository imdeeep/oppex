# Single-origin production setup (fully dockerized).
# Caddy terminates TLS and routes everything under one domain so the session
# cookie is first-party (works in Safari/Chrome). Service names below resolve
# on the Docker Compose network.
#
# Runs as the `caddy` service in docker-compose.yml.

oppex.duckdns.org {
    # API + session routes → Node BFF container
    handle /auth/* {
        reverse_proxy node-proxy:3000
    }
    handle /health {
        reverse_proxy node-proxy:3000
    }

    # Everything else → React SPA container (nginx)
    handle {
        reverse_proxy frontend:80
    }
}
