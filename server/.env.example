# Database (Neon / AWS RDS)
DB_USERNAME=neondb_owner
DB_PASSWORD=your_neon_password_here
DB_JDBC_URL=jdbc:postgresql://your-host.neon.tech/neondb?sslmode=require

# --- Option A: Gmail SMTP (recommended when recipients use Gmail) ---
# Gmail blocks @gmail.com senders that go through Brevo/other relays (DMARC quarantine).
# Use an App Password: https://myaccount.google.com/apppasswords
# Quick setup: ./scripts/setup-gmail.sh
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-account@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_FROM=your-account@gmail.com

# --- Option B: Brevo SMTP (works for test script; unreliable to Gmail inboxes) ---
# 1. Sign up at brevo.com
# 2. Settings → Senders → verify your Gmail (this becomes MAIL_FROM)
# 3. Settings → SMTP & API → SMTP tab → copy "SMTP login" and create SMTP key
#
# IMPORTANT: MAIL_USERNAME is the Brevo "SMTP login" (e.g. b0e9aa001@smtp-brevo.com),
# NOT your Gmail and NOT the key name. Shell exports of MAIL_* override this file —
# use ./scripts/dev.sh to start the server, or run: unset MAIL_USERNAME before quarkus:dev.
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-smtp-login-email@example.com
MAIL_PASSWORD=xsmtpsib-your-smtp-key-here
MAIL_FROM=your-verified-sender@gmail.com

# Optional: set false after mail works to skip startup SMTP check
# APP_MAIL_VALIDATE_ON_STARTUP=true
